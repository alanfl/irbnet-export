IRBNET_USERNAME=your_user_here
IRBNET_PASSWORD=your_pass_here

# Optional: set this to a native Chrome/Chromium executable when Puppeteer's bundled browser does not run.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Optional: set to true to run without a visible browser window.
# PUPPETEER_HEADLESS=true
